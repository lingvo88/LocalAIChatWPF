<Window x:Class="LocalAIChatWPF.ConversationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Conversations" Height="480" Width="560"
        Background="#1E1F22" WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Dark scrollbar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#2A2D34"/>
            <Setter Property="Foreground" Value="#4A4D55"/>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="#1E1F22"/>
        </Style>

        <!-- Dark ComboBox dropdown -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2D34"/>
            <Setter Property="Foreground" Value="#E8E8EA"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3D45"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#4A4D55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2D34"/>
            <Setter Property="Foreground" Value="#E8E8EA"/>
            <Setter Property="BorderBrush" Value="#3A3D45"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Background="#2A2D34" BorderBrush="#3A3D45"
                                  BorderThickness="1" Foreground="#E8E8EA"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  Padding="8,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="▾" Foreground="#8A8F98"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True">
                                <Border Background="#2A2D34" BorderBrush="#3A3D45" BorderThickness="1">
                                    <ItemsPresenter/>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#2A2D34"/>
            <Setter Property="Foreground" Value="#E8E8EA"/>
            <Setter Property="BorderBrush" Value="#3A3D45"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#E8E8EA"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A3D45"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2E3138"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2A2D34"/>
            <Setter Property="Foreground" Value="#E8E8EA"/>
            <Setter Property="BorderBrush" Value="#3A3D45"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3D45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2D34"/>
            <Setter Property="Foreground" Value="#E8E8EA"/>
            <Setter Property="BorderBrush" Value="#3A3D45"/>
            <Setter Property="CaretBrush" Value="#E8E8EA"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Double-click to open. Use buttons to rename or delete."
                   Foreground="#8A8F98" FontSize="12" Margin="0,0,0,8"/>

        <ListBox Grid.Row="1" x:Name="ConvoListBox"
                 Background="#2A2D34" Foreground="#E8E8EA"
                 BorderBrush="#3A3D45" BorderThickness="1"
                 MouseDoubleClick="ConvoListBox_DoubleClick"/>

        <!-- Rename row -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="RenameBox"
                     Margin="0,0,8,0"
                     ToolTip="Type a new name then click Rename"/>
            <Button Grid.Column="1" Content="Rename selected"
                    Click="RenameBtn_Click"/>
        </Grid>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Open selected" Margin="0,0,8,0" Click="OpenBtn_Click"/>
            <Button Content="Delete selected" Foreground="#C0392B"
                    Margin="0,0,8,0" Click="DeleteBtn_Click"/>
            <Button Content="Close" Click="CloseBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>