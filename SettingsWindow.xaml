<Window x:Class="LocalAIChatWPF.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="600" Width="520"
        Background="#1E1F22" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Dark scrollbar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#2A2D34"/>
            <Setter Property="Foreground" Value="#4A4D55"/>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="#1E1F22"/>
        </Style>

        <!-- Dark ComboBox dropdown -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2D34"/>
            <Setter Property="Foreground" Value="#E8E8EA"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3D45"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#4A4D55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2D34"/>
            <Setter Property="Foreground" Value="#E8E8EA"/>
            <Setter Property="BorderBrush" Value="#3A3D45"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Background="#2A2D34" BorderBrush="#3A3D45"
                                  BorderThickness="1" Foreground="#E8E8EA"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  Padding="8,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="▾" Foreground="#8A8F98"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True">
                                <Border Background="#2A2D34" BorderBrush="#3A3D45" BorderThickness="1">
                                    <ItemsPresenter/>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#2A2D34"/>
            <Setter Property="Foreground" Value="#E8E8EA"/>
            <Setter Property="BorderBrush" Value="#3A3D45"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#E8E8EA"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A3D45"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2E3138"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2A2D34"/>
            <Setter Property="Foreground" Value="#E8E8EA"/>
            <Setter Property="BorderBrush" Value="#3A3D45"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3D45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2D34"/>
            <Setter Property="Foreground" Value="#E8E8EA"/>
            <Setter Property="BorderBrush" Value="#3A3D45"/>
            <Setter Property="CaretBrush" Value="#E8E8EA"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#8A8F98"/>
            <Setter Property="Padding" Value="0,8,0,2"/>
        </Style>
        
       

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#2A2D34"/>
            <Setter Property="Foreground" Value="#E8E8EA"/>
            <Setter Property="BorderBrush" Value="#3A3D45"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="#2A2D34"
                            BorderBrush="#3A3D45" BorderThickness="1,1,1,0"
                            Padding="12,6" Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1E1F22"/>
                                <Setter Property="Foreground" Value="#E8E8EA"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3A3D45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        

    </Window.Resources>
 

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="#1E1F22" BorderBrush="#3A3D45">

            <!-- General tab -->
            <TabItem Header="General">
                <StackPanel Margin="8">
                    <Label Content="Server address:"/>
                    <TextBox x:Name="ServerUrlBox" Margin="0,0,0,4"/>
                    <Button Content="Test Connection" HorizontalAlignment="Left"
                            Margin="0,4,0,4" Click="TestConnection_Click"/>
                    <TextBlock x:Name="TestResultLabel" Foreground="#8A8F98"
                               FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>

                    <Label Content="AI name (shown in chat):"/>
                    <TextBox x:Name="AiNameBox" Margin="0,0,0,4"/>

                    <Label Content="System prompt (shared across all devices):"/>
                    <TextBox x:Name="SystemPromptBox" Height="220"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </TabItem>

            <!-- Memory tab -->
            <TabItem Header="Memory" GotFocus="MemoryTab_GotFocus">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Foreground="#8A8F98"
                               Text="Long-term facts the AI remembers about you:"
                               Margin="0,8,0,4"/>

                    <ListBox Grid.Row="1" x:Name="MemoryListBox"
                             Background="#2A2D34" Foreground="#E8E8EA"
                             BorderBrush="#3A3D45" Margin="0,0,0,8"/>

                    <Button Grid.Row="2" Content="Delete selected fact"
                            HorizontalAlignment="Left" Margin="0,0,0,8"
                            Click="DeleteFact_Click"/>

                    <TextBlock Grid.Row="3" Text="Add a fact manually:"
                               Foreground="#8A8F98" Margin="0,0,0,4"/>
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="NewFactBox"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Add"
                                Click="AddFact_Click"/>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save (starts new chat)" Margin="0,0,8,0"
                    Click="SaveBtn_Click"/>
            <Button Content="Close" Click="CloseBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>