<Window x:Class="LocalAIChatWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mdxaml="clr-namespace:MdXaml;assembly=MdXaml"
        Title="Local AI Chat" Height="750" Width="900"
        MinHeight="500" MinWidth="600"
        Background="#1E1F22"
        Closing="Window_Closing">

	<Window.Resources>
		<!-- Dark scrollbar -->
		<Style TargetType="ScrollBar">
			<Setter Property="Background" Value="#2A2D34"/>
			<Setter Property="Foreground" Value="#4A4D55"/>
		</Style>

		<Style TargetType="ScrollViewer">
			<Setter Property="Background" Value="#1E1F22"/>
		</Style>

		<!-- Dark ComboBox dropdown -->
		<Style TargetType="ComboBoxItem">
			<Setter Property="Background" Value="#2A2D34"/>
			<Setter Property="Foreground" Value="#E8E8EA"/>
			<Setter Property="Padding" Value="8,4"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ComboBoxItem">
						<Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
							<ContentPresenter/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#3A3D45"/>
							</Trigger>
							<Trigger Property="IsSelected" Value="True">
								<Setter Property="Background" Value="#4A4D55"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style TargetType="ComboBox">
			<Setter Property="Background" Value="#2A2D34"/>
			<Setter Property="Foreground" Value="#E8E8EA"/>
			<Setter Property="BorderBrush" Value="#3A3D45"/>
			<Setter Property="Padding" Value="8,4"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ComboBox">
						<Grid>
							<ToggleButton Background="#2A2D34" BorderBrush="#3A3D45"
										  BorderThickness="1" Foreground="#E8E8EA"
										  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
										  Padding="8,4">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="20"/>
									</Grid.ColumnDefinitions>
									<ContentPresenter Grid.Column="0"
													  Content="{TemplateBinding SelectionBoxItem}"
													  VerticalAlignment="Center"/>
									<TextBlock Grid.Column="1" Text="▾" Foreground="#8A8F98"
											   VerticalAlignment="Center" HorizontalAlignment="Center"/>
								</Grid>
							</ToggleButton>
							<Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True">
								<Border Background="#2A2D34" BorderBrush="#3A3D45" BorderThickness="1">
									<ItemsPresenter/>
								</Border>
							</Popup>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Dark ListBox -->
		<Style TargetType="ListBox">
			<Setter Property="Background" Value="#2A2D34"/>
			<Setter Property="Foreground" Value="#E8E8EA"/>
			<Setter Property="BorderBrush" Value="#3A3D45"/>
		</Style>

		<Style TargetType="ListBoxItem">
			<Setter Property="Foreground" Value="#E8E8EA"/>
			<Setter Property="Padding" Value="6,4"/>
			<Style.Triggers>
				<Trigger Property="IsSelected" Value="True">
					<Setter Property="Background" Value="#3A3D45"/>
				</Trigger>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#2E3138"/>
				</Trigger>
			</Style.Triggers>
		</Style>
		<Style TargetType="Button">
			<Setter Property="Background" Value="#2A2D34"/>
			<Setter Property="Foreground" Value="#E8E8EA"/>
			<Setter Property="BorderBrush" Value="#3A3D45"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="10,5"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#3A3D45"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter Property="Background" Value="#4A4D55"/>
							</Trigger>
							<Trigger Property="IsEnabled" Value="False">
								<Setter Property="Opacity" Value="0.4"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

	

		<Style TargetType="CheckBox">
			<Setter Property="Foreground" Value="#E8E8EA"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
		</Style>

		<Style TargetType="TextBox">
			<Setter Property="Background" Value="#2A2D34"/>
			<Setter Property="Foreground" Value="#E8E8EA"/>
			<Setter Property="BorderBrush" Value="#3A3D45"/>
			<Setter Property="CaretBrush" Value="#E8E8EA"/>
			<Setter Property="Padding" Value="8"/>
		</Style>
		<Style TargetType="TabControl">
			<Setter Property="Background" Value="#1E1F22"/>
			<Setter Property="BorderBrush" Value="#3A3D45"/>
		</Style>

		<Style TargetType="TabItem">
			<Setter Property="Background" Value="#2A2D34"/>
			<Setter Property="Foreground" Value="#E8E8EA"/>
			<Setter Property="BorderBrush" Value="#3A3D45"/>
			<Setter Property="Padding" Value="12,6"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TabItem">
						<Border x:Name="Border" Background="#2A2D34"
								BorderBrush="#3A3D45" BorderThickness="1,1,1,0"
								Padding="12,6" Margin="0,0,2,0">
							<ContentPresenter ContentSource="Header"
											  HorizontalAlignment="Center"
											  VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsSelected" Value="True">
								<Setter TargetName="Border" Property="Background" Value="#1E1F22"/>
								<Setter Property="Foreground" Value="#E8E8EA"/>
							</Trigger>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Border" Property="Background" Value="#3A3D45"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

	</Window.Resources>

	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="120"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Top bar: model selector + buttons -->
		<Grid Grid.Row="0" Margin="0,0,0,8">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			<TextBlock Grid.Column="0" Text="Model:" Foreground="#8A8F98"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
			<ComboBox Grid.Column="1" x:Name="ModelComboBox" Margin="0,0,8,0"/>
			<Button Grid.Column="2" x:Name="RefreshBtn" Content="Refresh"
                    Margin="0,0,4,0" Click="RefreshBtn_Click"/>
			<Button Grid.Column="3" Content="A-" Width="32" Margin="0,0,4,0" Click="FontSmaller_Click"/>
			<Button Grid.Column="4" Content="A+" Width="32" Margin="0,0,4,0" Click="FontLarger_Click"/>
			<Button Grid.Column="5" Content="Settings" Click="SettingsBtn_Click"/>
		</Grid>

		<!-- Chat display -->
		<ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      Background="#1E1F22" Padding="4">
			<StackPanel x:Name="ChatPanel" Margin="8"/>
		</ScrollViewer>

		<!-- File attachment label -->
		<TextBlock Grid.Row="2" x:Name="FileLabel"
                   Text="No file attached — drag a file onto this window, or use Attach File"
                   Foreground="#666" FontStyle="Italic" Margin="0,6,0,4"/>

		<!-- Input box -->
		<TextBox Grid.Row="3" x:Name="InputBox"
                 Background="#2A2D34" Foreground="#E8E8EA"
                 BorderBrush="#3A3D45" BorderThickness="1"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="Segoe UI" FontSize="14"
                 Padding="10" Margin="0,0,0,8"
				 SpellCheck.IsEnabled="True"
                 PreviewKeyDown="InputBox_PreviewKeyDown"
                 AllowDrop="True" Drop="InputBox_Drop"
                 DragOver="InputBox_DragOver"/>

		<!-- Button row -->
		<WrapPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,6">
			<Button Content="Attach File" Margin="0,0,6,4" Click="AttachBtn_Click"/>
			<Button Content="Export .txt" Margin="0,0,6,4" Click="ExportBtn_Click"/>
			<Button Content="Load Chat" Margin="0,0,6,4" Click="LoadChatBtn_Click"/>
			<Button Content="New Chat" Margin="0,0,6,4" Click="NewChatBtn_Click"/>
			<CheckBox x:Name="SearchToggle" Content="Search web" IsChecked="True"
                      Margin="4,0,12,0" VerticalAlignment="Center"/>
			<Button x:Name="StopBtn" Content="Stop" IsEnabled="False"
                    Foreground="#C0392B" Margin="0,0,6,4" Click="StopBtn_Click"/>
			<Button x:Name="SendBtn" Content="Send" Margin="0,0,0,4" Click="SendBtn_Click"/>
		</WrapPanel>

		<!-- Status bar -->
		<TextBlock Grid.Row="5" x:Name="StatusLabel"
                   Foreground="#8A8F98" FontStyle="Italic" FontSize="11"
                   Margin="2,0,0,2"/>
	</Grid>
</Window>